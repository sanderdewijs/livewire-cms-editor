# Keep dev-only files out of the Composer dist tarball (Packagist installs the
# git archive of the tag). dist/ and resources/ are intentionally NOT ignored.
/.github            export-ignore
/tests              export-ignore
/.gitattributes     export-ignore
/.gitignore         export-ignore
/.npmrc             export-ignore
/phpunit.xml        export-ignore
/renovate.json      export-ignore
/package-lock.json  export-ignore
/codedb.snapshot    export-ignore
